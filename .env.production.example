PORT=3001
NODE_ENV=production
CLIENT_ORIGIN=https://your-app-domain.com

JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

DATABASE_URL=postgresql://user:password@host:5432/lostandfound

# Docker Hub (for CI/CD)
DOCKER_USERNAME=your_dockerhub_username
PROD_API_URL=https://api.your-app-domain.com/api
